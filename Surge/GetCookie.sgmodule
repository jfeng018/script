#!name=Cookie 获取
#!desc=仅用于抓取 Cookie，完成后请及时关闭，避免不必要的 MITM
#!category=签到模块

[Script]
# > 百度贴吧 - c.tieba.baidu.com, tiebac.baidu.com
# 获取方式：打开 APP
百度贴吧_Cookie = type=http-request,pattern=^https?:\/\/(c\.tieba|tiebac)\.baidu\.com\/c\/s\/login,script-path=https://raw.githubusercontent.com/tutuh/script/master/task/tieba.js

# > 顺丰速运 - ccsp-egmas.sf-express.com
# 获取方式：APP → 我的 → 积分
顺丰速运_Cookie = type=http-request,pattern=^https:\/\/ccsp-egmas.sf-express.com\/cx-app-member\/member\/app\/user\/universalSign,requires-body=1,script-path=https://raw.githubusercontent.com/tutuh/script/master/task/sf.js

# > 途虎养车 - cl-gateway.tuhu.cn
# 获取方式：打开 APP
途虎养车_Cookie = type=http-request,pattern=https:\/\/cl-gateway\.tuhu\.cn\/.*,requires-body=0,script-path=https://raw.githubusercontent.com/tutuh/script/master/task/tuhu.js

[MITM]
hostname = %APPEND% c.tieba.baidu.com, tiebac.baidu.com, ccsp-egmas.sf-express.com, cl-gateway.tuhu.cn
