      "icons": [
        "https://raw.githubusercontent.com/tutuh/script/master/task/relx/Relx.png",
        "https://raw.githubusercontent.com/tutuh/script/master/task/relx/Relx.png"
      ]
    },
    {
      "id": "Tuhu",
      "name": "途虎养车",
      "author": "@FoKit",
      "script": "https://raw.githubusercontent.com/tutuh/script/refs/heads/master/task/tuhu.js",
      "repo": "",
      "icons": [
        "https://raw.githubusercontent.com/tutuh/icon/main/iconSet/tuhu.png",
        "https://raw.githubusercontent.com/tutuh/icon/main/iconSet/tuhu.png"
      ],
      "descs_html": ["途虎养车签到"],
      "keys": ["tuhu_token", "tuhu_blackbox"],
      "settings": [
        {
          "id": "tuhu_token",
          "name": "Token",
          "val": "",
          "type": "textarea",
          "autoGrow": true,
          "rows": 1,
          "desc": "活动 Token, 以数组字符串形式保存"
        },
        {
          "id": "tuhu_blackbox",
          "name": "Blackbox",
          "val": "",
          "type": "text",
          "desc": ""
        }
      ]
    },
           {
      "id": "SFexpress",
      "name": "顺丰速运",
      "keys": ["sfexpress_session"],
      "author": "@wangfei021325, @chavyleung",
      "repo": "https://github.com/tutuh/script/tree/master",
      "script": "https://raw.githubusercontent.com/tutuh/script/refs/heads/master/task/sf.js",
      "icons": [
        "https://raw.githubusercontent.com/tutuh/icon/main/iconSet/sfexpress-Light.png",
